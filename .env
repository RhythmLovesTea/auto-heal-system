# AutoHeal environment config
# Copy to .env and adjust before running

# Polling
POLL_INTERVAL=30
HEAL_COOLDOWN=60

# Docker
DOCKER_SOCKET=unix://var/run/docker.sock
CONTAINER_FILTER=[]          # e.g. '["payments-api","worker"]' to scope monitoring

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL=86400

# Logging
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false               # true = structured JSON logs (good for prod)

# Victim service chaos tuning
CRASH_PROBABILITY=0.3
SLOW_PROBABILITY=0.2
